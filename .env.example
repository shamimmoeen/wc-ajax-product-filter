# Docker dev environment configuration for WCAPF.
# Copy this file to .env and adjust as needed.

# Host port for the WCAPF site. Use a different port if running both pro and free in parallel.
WCAPF_HTTP_PORT=8081

# Host port exposed for the MariaDB container (for direct DB access from host).
WCAPF_DB_PORT=3308

# PHP version used by the php-fpm and wp-cli containers.
PHP_VERSION=8.2

# UID/GID for PHP-FPM to match your host user (run `id -u` and `id -g`).
PHP_FPM_UID=1000
PHP_FPM_GID=1000

# WordPress debug mode. 1 = WP_DEBUG + WP_DEBUG_LOG + SCRIPT_DEBUG + SAVEQUERIES on; 0 = all off.
# Toggle requires `docker compose up -d --force-recreate php` to pick up the change.
WP_DEBUG=1

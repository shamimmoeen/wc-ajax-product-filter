<?xml version="1.0"?>
<ruleset name="WCAPF – Ajax Product Filter for WooCommerce">

	<description>A custom set of rules to check for WCAPF – Ajax Product Filter for WooCommerce plugin</description>

	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>
	<exclude-pattern>/docker/*</exclude-pattern>
	<exclude-pattern>/tests/*</exclude-pattern>
	<exclude-pattern>/bin/*</exclude-pattern>

	<rule ref="WordPress-Extra"/>

	<!-- PSR-4 namespaced files use PascalCase filenames; legacy files use class-foo.php. -->
	<rule ref="WordPress.Files.FileName">
		<exclude-pattern>/includes/Plugin.php</exclude-pattern>
		<exclude-pattern>/includes/Helpers/*</exclude-pattern>
		<exclude-pattern>/includes/Hooks/*</exclude-pattern>
		<exclude-pattern>/includes/Migration/*</exclude-pattern>
	</rule>

	<!-- Inline comments do not need to end with a full stop. -->
	<rule ref="Squiz.Commenting.InlineComment">
		<exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
	</rule>

	<!-- Files may contain both a class and a companion helper function — common WordPress pattern. -->
	<rule ref="Universal.Files.SeparateFunctionsFromOO">
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed"/>
	</rule>

	<rule ref="WordPress-Docs"/>

	<rule ref="Generic.CodeAnalysis.UnusedFunctionParameter"/>

	<!-- Line length is not enforced; SQL strings and hook names routinely exceed any reasonable limit. -->
	<rule ref="Generic.Files.LineLength">
		<exclude name="Generic.Files.LineLength.TooLong"/>
		<exclude name="Generic.Files.LineLength.MaxExceeded"/>
	</rule>

	<!-- Check PHP cross-version compatibility -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP"/>

	<config name="minimum_supported_wp_version" value="6.3"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="wc-ajax-product-filter"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="wcapf"/>
			</property>
		</properties>
	</rule>

</ruleset>
